# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here

# Firebase Admin SDK Credentials
# Note: In production, store the service account JSON contents or pass file path
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Twilio SMS API Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OpenAI API Key
OPENAI_API_KEY=

# Google Speech-To-Text Credentials (optional if using OpenAI whisper or direct Google API client credentials)
GOOGLE_APPLICATION_CREDENTIALS=
