# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here

# Firebase Admin SDK Credentials
# Note: In production, store the service account JSON contents or pass file path
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_STORAGE_BUCKET=your-app-bucket.appspot.com

# Twilio SMS API Credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Google Speech-To-Text Credentials (optional if using OpenAI whisper or direct Google API client credentials)
GOOGLE_APPLICATION_CREDENTIALS=path/to/google/credentials.json
